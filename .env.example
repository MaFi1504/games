# Public URL of the site (used for WebSocket Origin validation, no trailing slash)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Multiplayer server limits (all optional — defaults shown)
# Maximum players per room
MP_MAX_ROOM_SIZE=10
# Maximum concurrent rooms
MP_MAX_ROOMS=10
# Maximum WebSocket connections per IP
MP_MAX_CONNS_PER_IP=20
# Maximum messages per peer per second before frames are dropped
MP_RATE_LIMIT_MESSAGES=20
# Maximum raw WebSocket message size in bytes before JSON.parse
MP_MSG_MAX_BYTES=8192
# Maximum player display-name length in characters
MP_NAME_MAX=30
# Maximum game-state JSON blob size in bytes
MP_STATE_JSON_MAX=4096