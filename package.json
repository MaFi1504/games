{
  "name": "games",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --project unit --run",
    "test:nuxt": "vitest --project nuxt --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint --fix && pnpm test:unit"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.105",
    "@iconify-json/simple-icons": "^1.2.80",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/i18n": "^10.4.0",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "^1.59.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "playwright-core": "^1.59.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "brace-expansion": "^5.0.6",
      "ws": "^8.20.1",
      "vue": "3.5.34",
      "@vue/compiler-sfc": "3.5.34",
      "@vue/runtime-core": "3.5.34",
      "@vue/runtime-dom": "3.5.34",
      "@vue/server-renderer": "3.5.34"
    }
  }
}
